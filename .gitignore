# AoC policy: puzzle input not shared
puzzle_input.txt

# Ignore everything inside runs/ by default
runs/**

# Whitelist only what we want
!runs/
!runs/baseline/
!runs/baseline/final/
!runs/baseline/final/metrics.json
!runs/baseline/final/metrics.csv
!runs/baseline/final/gds/
!runs/baseline/final/gds/*.gds
!runs/baseline/final/klayout_gds/
!runs/baseline/final/klayout_gds/*.gds
!runs/aggressive/
!runs/aggressive/final/
!runs/aggressive/final/metrics.json
!runs/aggressive/flow.log
!runs/aggressive_pipelined/
!runs/aggressive_pipelined/final/
!runs/aggressive_pipelined/final/metrics.json
!runs/aggressive_pipelined/final/metrics.csv
!runs/pipelined/
!runs/pipelined/final/
!runs/pipelined/final/metrics.json
!runs/pipelined/final/metrics.csv
!runs/pipelined/final/klayout_gds/
!runs/pipelined/final/klayout_gds/*.gds

# OpenLane runs inside src/
src/runs/

# Build / sim artifacts
test/sim_build/
test/results.xml
test/*.vcd

# Python
**/__pycache__/
**/.venv*/
*.pyc

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store

# Local-only progress notes (not for github)
CHECKPOINT_PHASE3.md
